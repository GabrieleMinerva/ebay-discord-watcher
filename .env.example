# Core eBay OAuth (required)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope

# Discord webhook used in config.render.yaml placeholder
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_URL_DEALS=https://discord.com/api/webhooks/aaa/bbb

# Optional (for future Google integrations)
GOOGLE_API_KEY=your_google_api_key

# App runtime
CONFIG_PATH=config.render.yaml
SQLITE_PATH=./posted_items.sqlite
LOG_LEVEL=INFO

# Discord anti-rate-limit tuning
DISCORD_POST_DELAY_SECONDS=0.4
DISCORD_MAX_POSTS_PER_RUN=8
DISCORD_MAX_RETRIES=3

# eBay fetch tuning
EBAY_SEARCH_LIMIT=30
